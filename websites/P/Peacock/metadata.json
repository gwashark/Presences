{
  "$schema": "https://schemas.premid.app/metadata/1.16",
  "apiVersion": 1,
  "author": {
    "name": "Kedi",
    "id": "238668511222693888"
  },
  "contributors": [
    {
      "name": "hash.king",
      "id": "608311692644057088"
    },
